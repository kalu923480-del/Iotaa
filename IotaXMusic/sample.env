# ── Render / PaaS ──────────────────────────────────────────────────────────
# Render injects PORT automatically. Health server binds to this.
PORT=8080
# Optional override if RENDER_EXTERNAL_URL is missing:
# KEEPALIVE_URL=https://iota-music.onrender.com

# ── Required Telegram ──────────────────────────────────────────────────────
API_ID=
API_HASH=
BOT_TOKEN=
OWNER_ID=
# Log group/channel ID (negative). 0 = disable log features
LOGGER_ID=0
# Pyrogram userbot session (generate with: python3 session.py)
STRING_SESSION=
# Optional extra assistants
STRING2=
STRING3=
STRING4=
STRING5=

# ── Database ───────────────────────────────────────────────────────────────
MONGO_DB_URI=

# ── YouTube (required for reliable YT downloads) ───────────────────────────
# Raw URL to Netscape cookies.txt (Pastebin/Batbin unlisted)
COOKIE_URL=

# ── Optional download APIs ─────────────────────────────────────────────────
API_KEY=
API_URL=
VIDEO_API_URL=
DEEP_API=

# ── Spotify (optional) ─────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── Heroku (optional) ──────────────────────────────────────────────────────
HEROKU_API_KEY=
HEROKU_APP_NAME=

# ── AI chat (optional — /ai) ───────────────────────────────────────────────
AI_PROVIDER=openai
AI_API_KEY=
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=1024
AI_SYSTEM_PROMPT=You are Iota, a helpful, friendly AI assistant inside the Iota Music Bot.

# ── Limits / behaviour ─────────────────────────────────────────────────────
DURATION_LIMIT=60
PLAYLIST_FETCH_LIMIT=25
AUTO_LEAVING_ASSISTANT=true
AUTO_LEAVE_ASSISTANT_TIME=540
# Comma-separated chat IDs assistant must never auto-leave
PROTECTED_CHAT_IDS=

# ── Branding (optional) ────────────────────────────────────────────────────
BOT_USERNAME=Iotamusicbot
SUPPORT_CHAT=https://t.me/IotaDiscussion
SUPPORT_CHANNEL=https://t.me/Iota
STICKERS=
# Loading texts for /play separated by ||
AYU=
AYUV=

# ── Upstream (optional) ────────────────────────────────────────────────────
UPSTREAM_REPO=https://github.com/Iota/IotaXMusic
UPSTREAM_BRANCH=main
GIT_TOKEN=
